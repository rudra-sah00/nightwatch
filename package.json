{
  "name": "nightwatch",
  "description": "Nightwatch Desktop Application",
  "author": "Nightwatch Labs <rudranarayanaknr@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudra-sah00/nightwatch.git"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome check --write .",
    "prepare": "husky",
    "check": "biome check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "for key in $(redis-cli --scan --pattern 'security:*' 2>/dev/null); do redis-cli del $key; done; for key in $(redis-cli --scan --pattern 'auth:otp_limit*' 2>/dev/null); do redis-cli del $key; done; npx playwright test",
    "version": "node -p \"require('./package.json').version\"",
    "desktop:start": "electron .",
    "desktop:build": "electron-builder --mac --win --linux && bash scripts/resign-mac.sh desktop-build/mac-arm64/Nightwatch.app",
    "mobile:build": "npx cap sync",
    "mobile:sync": "npx cap sync",
    "mobile:ios": "CAPACITOR_DEV=true npx cap sync ios && npx cap open ios",
    "mobile:android": "CAPACITOR_DEV=true npx cap sync android && npx cap open android"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@anuradev/capacitor-phone-call-notification": "^7.5.5",
    "@capacitor-community/keep-awake": "^8.0.1",
    "@capacitor-community/volume-buttons": "8.0.0",
    "@capacitor-firebase/analytics": "^8.3.0",
    "@capacitor-firebase/crashlytics": "^8.3.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "8.0.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome/capacitor-badge": "^8.0.2",
    "@capgo/capacitor-incoming-call-kit": "^8.1.1",
    "@capgo/capacitor-social-login": "^8.3.29",
    "@marsidev/react-turnstile": "^1.4.1",
    "@mediapipe/tasks-vision": "^0.10.32",
    "@ottimis/capacitor-volumes": "7.0.0",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "5.80.6",
    "agora-rtc-sdk-ng": "^4.24.4",
    "agora-rtm-sdk": "2.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "debug": "^4.4.3",
    "discord-rpc": "^4.0.1",
    "driver.js": "^1.4.0",
    "electron-context-menu": "^4.1.2",
    "electron-log": "^5.4.4",
    "electron-store": "11.0.2",
    "electron-updater": "^6.8.9",
    "electron-window-state": "^5.0.3",
    "emoji-picker-react": "^4.17.1",
    "firebase": "12.14.0",
    "hls.js": "^1.6.16",
    "jsqr": "1.4.0",
    "konva": "^10.2.0",
    "lucide-react": "^1.21.0",
    "material-symbols": "^0.44.1",
    "ms": "^2.1.3",
    "next": "16.1.6",
    "next-intl": "^4.9.1",
    "nprogress": "^0.2.0",
    "qrcode": "1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-konva": "^19.2.5",
    "react-loading-skeleton": "3.5.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@capacitor/cli": "^8.3.1",
    "@electron/asar": "^4.2.0",
    "@electron/fuses": "^2.1.2",
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "5.80.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/nprogress": "^0.2.3",
    "@types/qrcode": "1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^42.4.1",
    "electron-builder": "^26.8.1",
    "happy-dom": "^20.4.0",
    "husky": "^9.1.7",
    "javascript-obfuscator": "^5.4.3",
    "jsdom": "29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "main": "electron/main.js",
  "build": {
    "afterPack": "./scripts/afterPack.cjs",
    "afterSign": "./scripts/afterSign.cjs",
    "asar": true,
    "files": [
      "electron/**/*",
      "package.json",
      {
        "from": "node_modules_electron",
        "to": "node_modules",
        "filter": [
          "**/*",
          "!**/android/build/**",
          "!**/android/.gradle/**",
          "!**/.git/**",
          "!**/*.md",
          "!**/*.map",
          "!**/test/**",
          "!**/tests/**",
          "!**/__tests__/**"
        ]
      },
      "!node_modules",
      "!src",
      "!public",
      "!ios",
      "!android",
      "!.next",
      "!.git",
      "!desktop-build",
      "!docs",
      "!tests",
      "!coverage",
      "!.venv"
    ],
    "npmRebuild": false,
    "appId": "com.nightwatch.app",
    "productName": "Nightwatch",
    "copyright": "© 2026 Nightwatch Labs",
    "directories": {
      "output": "desktop-build"
    },
    "mac": {
      "entitlements": "electron/build/entitlements.mac.plist",
      "entitlementsInherit": "electron/build/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "We need camera access for live streaming.",
        "NSMicrophoneUsageDescription": "We need microphone access for voice chat."
      },
      "category": "public.app-category.entertainment",
      "icon": "electron/build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/build/icon.png",
      "legalTrademarks": "© 2025 Nightwatch Labs"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "Nightwatch",
      "installerIcon": "electron/build/icon.ico",
      "uninstallerIcon": "electron/build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "electron/build/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "rudra-sah00",
        "repo": "nightwatch",
        "releaseType": "release"
      }
    ]
  },
  "version": "2.14.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "patchedDependencies": {
      "@capacitor-community/volume-buttons@8.0.0": "patches/@capacitor-community__volume-buttons@8.0.0.patch",
      "@anuradev/capacitor-phone-call-notification@7.5.5": "patches/@anuradev__capacitor-phone-call-notification@7.5.5.patch",
      "@ottimis/capacitor-volumes": "patches/@ottimis__capacitor-volumes.patch"
    }
  },
  "packageManager": "pnpm@10.29.2"
}
