{
  "name": "watch-rudra",
  "description": "Watch Rudra Desktop Application",
  "author": "Rudra Sah00 <rudranarayanaknr@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudra-sah00/watch-rudra.git"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome check --write .",
    "prepare": "husky",
    "check": "biome check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "for key in $(redis-cli --scan --pattern 'security:*' 2>/dev/null); do redis-cli del $key; done; for key in $(redis-cli --scan --pattern 'auth:otp_limit*' 2>/dev/null); do redis-cli del $key; done; npx playwright test",
    "version": "node -p \"require('./package.json').version\"",
    "desktop:start": "electron .",
    "desktop:build": "electron-builder --mac --win --linux"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.4.1",
    "@mediapipe/tasks-vision": "^0.10.32",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/electron": "^7.11.0",
    "@sentry/nextjs": "^10.47.0",
    "@types/video.js": "^7.3.58",
    "agora-rtc-sdk-ng": "^4.24.2",
    "agora-rtm-sdk": "2.2.3-1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "discord-rpc": "^4.0.1",
    "driver.js": "^1.4.0",
    "electron-asar-hot-updater": "^0.1.3",
    "electron-context-menu": "^4.1.2",
    "electron-log": "^5.4.3",
    "electron-store": "8.2.0",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3",
    "emoji-picker-react": "^4.17.1",
    "hls.js": "^1.6.15",
    "konva": "^10.2.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-konva": "^19.2.2",
    "react-markdown": "^10.1.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "use-image": "^1.1.4",
    "video.js": "^8.23.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "happy-dom": "^20.4.0",
    "husky": "^9.1.7",
    "jsdom": "26.0.0",
    "lint-staged": "^16.2.7",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "main": "electron/main.js",
  "build": {
    "files": [
      "electron/**/*",
      "package.json",
      "!src/**/*",
      "!public/**/*",
      "!tests/**/*",
      "!.next/**/*",
      "!docs/**/*",
      "!coverage/**/*",
      "!node_modules/next/**/*",
      "!node_modules/@next/**/*",
      "!node_modules/react/**/*",
      "!node_modules/react-dom/**/*",
      "!node_modules/@mediapipe/**/*",
      "!node_modules/agora-*/**/*",
      "!node_modules/konva/**/*",
      "!node_modules/react-konva/**/*",
      "!node_modules/video.js/**/*",
      "!node_modules/hls.js/**/*",
      "!node_modules/@radix-ui/**/*",
      "!node_modules/lucide-react/**/*",
      "!node_modules/tailwindcss*/**/*",
      "!node_modules/@sentry/nextjs/**/*",
      "!node_modules/zod/**/*",
      "!node_modules/socket.io-client/**/*",
      "!node_modules/emoji-picker-react/**/*",
      "!node_modules/driver.js/**/*"
    ],
    "npmRebuild": false,
    "appId": "com.watchrudra.app",
    "productName": "Watch Rudra",
    "directories": {
      "output": "desktop-build"
    },
    "mac": {
      "identity": null,
      "entitlements": "electron/build/entitlements.mac.plist",
      "entitlementsInherit": "electron/build/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "We need camera access for live streaming.",
        "NSMicrophoneUsageDescription": "We need microphone access for voice chat."
      },
      "category": "public.app-category.entertainment",
      "icon": "electron/build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "electron/build/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "rudra-sah00",
        "repo": "watch-rudra",
        "releaseType": "release"
      }
    ]
  },
  "version": "1.16.0"
}
