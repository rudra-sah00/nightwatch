{
  "name": "watch-rudra",
  "description": "Watch Rudra Desktop Application",
  "author": "Rudra Sah00 <rudranarayanaknr@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudra-sah00/watch-rudra.git"
  },
  "private": true,
  "scripts": {
    "dev": "concurrently -p none 'serwist build --watch' 'next dev'",
    "build": "next build && serwist build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome check --write .",
    "prepare": "husky",
    "check": "biome check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "for key in $(redis-cli --scan --pattern 'security:*' 2>/dev/null); do redis-cli del $key; done; for key in $(redis-cli --scan --pattern 'auth:otp_limit*' 2>/dev/null); do redis-cli del $key; done; npx playwright test",
    "version": "node -p \"require('./package.json').version\"",
    "desktop:start": "electron .",
    "desktop:build": "electron-builder --mac --win --linux"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
