# Backend API URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# CF Worker URL (dev only — matches CF_WORKER_URL in backend .env)
NEXT_PUBLIC_CF_WORKER_URL=http://localhost:8787

# WebSocket URL
NEXT_PUBLIC_WS_URL=http://localhost:4000

# Agora App ID (Development)
NEXT_PUBLIC_AGORA_APP_ID=3cf2d97578e14465af1967b786346f06

# Agora SDK debug logging (false = silent, true = full debug output in dev)
NEXT_PUBLIC_AGORA_DEBUG=false

# E2E Test Credentials (Playwright — copy to .env.test locally)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
E2E_TEST_OTP=000000
