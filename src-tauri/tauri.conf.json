{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Watch Rudra",
  "version": "1.32.0",
  "identifier": "com.watchrudra.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "https://watch.rudrasahoo.live"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 540,
        "center": true,
        "visible": false,
        "decorations": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["watch-rudra"]
      },
      "mobile": [
        {
          "scheme": ["watch-rudra"],
          "appLink": false
        },
        {
          "scheme": ["https"],
          "host": "watch.rudrasahoo.live",
          "pathPrefix": ["/"],
          "appLink": true
        }
      ]
    },
    "updater": {
      "endpoints": [
        "https://github.com/rudra-sah00/watch-rudra/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    },
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "iOS": {
      "developmentTeam": ""
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}
