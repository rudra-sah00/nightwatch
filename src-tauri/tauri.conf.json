{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Watch Rudra",
  "version": "1.32.0",
  "identifier": "com.watchrudra.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 540,
        "center": true,
        "visible": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "url": "https://watch.rudrasahoo.live"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["watch-rudra"]
      },
      "mobile": {
        "schemes": ["watch-rudra"],
        "android": {
          "hosts": [
            {
              "name": "watch.rudrasahoo.live",
              "pathPrefix": "/"
            }
          ]
        },
        "ios": {
          "applinks": ["watch.rudrasahoo.live"]
        }
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/rudra-sah00/watch-rudra/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    },
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "iOS": {
      "developmentTeam": ""
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}
